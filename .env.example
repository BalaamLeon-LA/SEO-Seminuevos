# Copia este archivo a .env y completa los valores

# Portal a testear: MX o EC (default: MX)
COUNTRY=MX

# URL base de producción. Normalmente NO se define: se infiere de COUNTRY
# (MX -> https://www.seminuevos.com, EC -> https://ecuador.patiotuerca.com).
# Solo úsala para forzar un dominio distinto al de COUNTRY.
# PRODUCTION_BASE_URL=

# URL base del ambiente de staging o demo, una por país
# Ejemplo: https://staging.seminuevos.com  o  https://demo.seminuevos.com
DEMO_BASE_URL_MX=
DEMO_BASE_URL_EC=
